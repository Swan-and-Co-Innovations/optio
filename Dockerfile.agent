# Dockerfile.agent — GSD-2 + code-review-graph agent image
#
# Installs:
#   - Node 22 (for gsd-pi / GSD-2)
#   - Python 3 + pip (for code-review-graph)
#   - git (required by both GSD-2 and code-review-graph)
#
# Usage (build):
#   docker build -f Dockerfile.agent -t gsd-agent:m001 .
#
# Usage (run):
#   docker run --rm gsd-agent:m001 gsd --version
#   docker run --rm gsd-agent:m001 code-review-graph --version

# Using MCR-hosted Node image to avoid Docker Hub pull rate limits during az acr build.
# Bookworm (Debian 12) ships Python 3.11 — required by code-review-graph (>=3.10).
# Bullseye only has Python 3.9 and all code-review-graph versions fail the constraint.
FROM mcr.microsoft.com/devcontainers/javascript-node:22-bookworm

# ── System dependencies ──────────────────────────────────────────────────────
# python3-pip provides pip for the system python (Debian-patched, no ensurepip).
# git is required at runtime by GSD-2 and code-review-graph.
RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 \
      python3-pip \
      git \
    && rm -rf /var/lib/apt/lists/*

# ── Python encoding fix ───────────────────────────────────────────────────────
# Force UTF-8 I/O for all Python processes so pip output doesn't trigger
# 'charmap' UnicodeEncodeError when the ACR log streamer runs on Windows.
ENV PYTHONUTF8=1
ENV PYTHONIOENCODING=utf-8

# ── code-review-graph ─────────────────────────────────────────────────────────
# --no-color --quiet suppresses Unicode progress characters in pip output.
# Using python3 -m pip (not pip3) for Debian bookworm compatibility.
RUN python3 -m pip install --break-system-packages --no-color --quiet code-review-graph

# ── gsd-pi (GSD-2) via npm ────────────────────────────────────────────────────
# PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 prevents the gsd-pi postinstall hook from
# downloading ~300 MB of Chromium that the headless agent never uses.
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
RUN npm install -g gsd-pi

# ── MCP configuration ─────────────────────────────────────────────────────────
# mcp-defaults.json is copied in and made readable; actual GSD-2 config is
# written at container startup by repo-init.sh.
COPY scripts/mcp-defaults.json /opt/agent/mcp-defaults.json

# ── Bootstrap script ──────────────────────────────────────────────────────────
COPY scripts/repo-init.sh /opt/agent/repo-init.sh
RUN chmod +x /opt/agent/repo-init.sh

# ── Agent entrypoint ──────────────────────────────────────────────────────────
# Chains repo-init.sh → gsd headless --auto.
# See scripts/agent-entrypoint.sh for full documentation.
COPY scripts/agent-entrypoint.sh /opt/agent/agent-entrypoint.sh
RUN chmod +x /opt/agent/agent-entrypoint.sh

# ── Working directory ─────────────────────────────────────────────────────────
# ACA Jobs mount the repo under /workspace at runtime.
WORKDIR /workspace

# ── Entry point ───────────────────────────────────────────────────────────────
# ENTRYPOINT runs agent-entrypoint.sh unconditionally on every container start.
# ACA Job may pass additional arguments via the job definition's args field.
ENTRYPOINT ["/opt/agent/agent-entrypoint.sh"]
